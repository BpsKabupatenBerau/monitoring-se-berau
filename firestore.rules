rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Users Collection
    match /users/{userId} {
      allow read: if true;
      allow write: if isValidId(userId);
    }

    // Plots Collection
    match /plots/{plotId} {
      allow read: if true;
      allow write: if isValidId(plotId);
    }

    // Submissions Collection
    match /submissions/{subId} {
      allow read: if true;
      allow write: if isValidId(subId);
    }

    // Issues Collection
    match /issues/{issueId} {
      allow read: if true;
      allow write: if isValidId(issueId);
    }
  }
}
